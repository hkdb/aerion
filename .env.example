# OAuth Credentials for Gmail and Outlook support
# Copy this file to .env or .env.local and fill in your values
#
# For development: use .env.local (takes precedence, not committed)
# For CI/builds: use .env or environment variables
#
# Get these from:
# - Google: https://console.cloud.google.com (APIs & Services > Credentials)
# - Microsoft: https://portal.azure.com (Azure Active Directory > App registrations)

# Google OAuth (from Google Cloud Console)
# Create a "Desktop app" OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (from Azure Portal)
# Create a "Public client/native" app registration.
# This client also serves the Contacts + Calendar extensions — Microsoft Graph
# doesn't gate scopes behind verification, so add Contacts.ReadWrite and
# Calendars.ReadWrite to this same registration. Picker UI surfaces it as
# "Aerion - Microsoft".
MICROSOFT_CLIENT_ID=your-application-client-id

# Google OAuth (testing client) for first-party extensions that need broader
# Google scopes than the mail-app's verified client carries — e.g.,
# contacts.readwrite, full Calendar. Single un-Google-verified test project
# backs the Contacts AND Calendar extensions. Surfaced in the picker UI as
# "Aerion - Google (Testing)" so users understand they may see the
# unverified-app warning during OAuth consent. Empty until provisioned;
# picker omits the (Testing) option in that case.
GOOGLE_TESTING_CLIENT_ID=
GOOGLE_TESTING_CLIENT_SECRET=
